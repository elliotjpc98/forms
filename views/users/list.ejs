<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Our Current Users</h1>
    <ul>
    <%  
        let users = locals.users;
        for (user of users){
            let id = users.indexOf(user);
    %>
            <li><a href="/users/<%= id %>">
                <%= user.firstName %>
                <%= user.lastName %></a>
                <%= user.age %>
                <%= user.gender %>
            </li>
    <% } %>
    </ul>
</body>
</html>