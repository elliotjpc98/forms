<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <form action="/users" method="post">
        <label for="firstName">
            First Name:
            <input type="text" name="firstName" value = "<%= locals.firstName %>">
        </label>
        <br>
        <label for="lastName">
            Last Name:
            <input type="text" name="lastName" value = "<%=locals.lastName %>">
        </label>
        <br>
        <label for="age">
            Age:
            <input type="number" name="age" min="0" value = "<%=locals.age %>">
        </label>
        <br>
        <label for="gender">
            Gender:
            <input type="text" name="gender" value = "<%=locals.gender %>">
        </label>
        <br>
        <button type="submit">Submit</button>
    </form>
</body>
</html>